<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- full-bleed diagonal green gradient (the launcher masks the corners) -->
    <path android:pathData="M0,0 H108 V108 H0 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="6" android:startY="6"
                android:endX="102" android:endY="102"
                android:startColor="#FF4CAF50"
                android:endColor="#FF1B5E20" />
        </aapt:attr>
    </path>
    <!-- soft top-left sheen for depth -->
    <path android:pathData="M0,0 H108 V108 H0 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="32" android:centerY="26"
                android:gradientRadius="90"
                android:startColor="#42FFFFFF"
                android:endColor="#00FFFFFF" />
        </aapt:attr>
    </path>
</vector>
